# =============================================================================
# @satsu/scanner — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
#
# Required:
#   VIEW_PRIVATE_KEY  — 32-byte hex view key for stealth payment detection
#   SPEND_PUBLIC_KEY  — 33-byte hex compressed spend public key
#   POOL_CONTRACT     — Deployed pool contract identifier
#
# Everything else has sensible defaults for local devnet.
# =============================================================================

# [REQUIRED] View private key (64-char hex, no 0x prefix)
VIEW_PRIVATE_KEY=

# [REQUIRED] Spend public key (66-char hex, compressed secp256k1)
SPEND_PUBLIC_KEY=

# [REQUIRED] Pool contract address (deployer.contract-name)
POOL_CONTRACT=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.pool-v1

# HTTP port for webhook receiver (default: 3100)
PORT=3200

# Stacks API URL
STACKS_API_URL=http://localhost:3999

# Network target
NETWORK=devnet

# Scanner mode: chainhook (real-time webhooks) or polling (periodic API queries)
MODE=polling

# Polling interval (ms) — only used in polling mode
POLLING_INTERVAL_MS=15000

# Optional: webhook URL for payment notifications
# NOTIFICATION_WEBHOOK_URL=https://your-app.com/api/payments

# Logging level
LOG_LEVEL=info

# =============================================================================
# @satsu/relay — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
#
# Required:
#   RELAYER_PRIVATE_KEY — 64-char hex private key for signing withdrawal txs
#
# Everything else has sensible defaults for local devnet.
# =============================================================================

# [REQUIRED] Relayer signing key (64-char hex, no 0x prefix)
RELAYER_PRIVATE_KEY=

# HTTP port (default: 3100)
PORT=3100

# Stacks API URL
#   devnet:  http://localhost:3999
#   testnet: https://api.testnet.hiro.so
#   mainnet: https://api.hiro.so
STACKS_API_URL=http://localhost:3999

# Network target
NETWORK=devnet

# Pool contract address (deployer.contract-name)
POOL_CONTRACT=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.pool-v1

# sBTC token contract address
SBTC_CONTRACT=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.sbtc-token

# Fee configuration
BASE_FEE=10000
FEE_PERCENTAGE=0.01
MAX_FEE=500000

# Batch processing delay (ms between tx submissions)
BATCH_DELAY_MS=15000

# Queue persistence file path
QUEUE_PERSIST_PATH=./data/queue.json

# Optional: human-readable relayer name
# RELAYER_NAME=satsu-relay-1

# Logging level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info
